        <PackageTags>GameFrameX,Lib,Utility,Server,GameServer</PackageTags>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
        <DefineConstants>TRACE;FP</DefineConstants>
