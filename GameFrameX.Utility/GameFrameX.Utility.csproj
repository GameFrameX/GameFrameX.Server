    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <DefineConstants>TRACE;FP</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="GameFrameX.Foundation.Logger" Version="2.2.8"/>
        <PackageReference Include="GameFrameX.Foundation.Utility" Version="2.2.8"/>
        <PackageReference Include="Lib.Harmony" Version="2.4.2"/>
        <PackageReference Include="SharpZipLib" Version="1.4.2"/>
        <PackageReference Include="Tedd.RandomUtils" Version="1.0.6"/>
        <PackageReference Include="Mapster" Version="7.4.0"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../GameFrameX.Localization/GameFrameX.Localization.csproj"/>
    </ItemGroup>

</Project>
